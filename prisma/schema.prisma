generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  avatar    String?
  phone     String?
  address   String?
  city      String?
  role      UserRole @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Just reference the inverse side — no fields/references here
  student   Student?
  teacher   Teacher?

  @@map("users")
}

model Student {
  id           String   @id @default(cuid())
  studentId    String?  @unique
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName     String
  fatherName   String
  motherName   String
  city         String
  address      String?
  grade        String
  degree       String?
  session      String?
  documentUrl  String?     // কলেজ চেঞ্জের প্রমাণ (PDF/Image link)
  status       StudentStatus @default(PENDING)
  dateJoined   DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payments     Payment[]
  schedules    Schedule[]
  comments     Comment[]

  @@map("students")
}



model Teacher {
  id         String   @id @default(cuid())
  teacherId  String?  @unique
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  subject    String?
  expertise  String[]
  status     TeacherStatus @default(PENDING)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  schedules  Schedule[]

  @@map("teachers")
}


model Payment {
  id          String        @id @default(cuid())
  paymentId   String        @unique
  amount      Float
  status      PaymentStatus
  paymentDate DateTime
  description String?

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model Schedule {
  id        String        @id @default(cuid())
  title     String
  subject   String
  date      DateTime
  startTime String
  endTime   String
  grade     String
  color     ScheduleColor @default(BLUE)

  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("schedules")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("comments")
}

// Other models (Message, Activity, Event) এখানে রাখবে তোমার আগের মতো

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
  STAFF
  PENDING
}

enum StudentStatus {
  PENDING
  ACTIVE
  INACTIVE
  GRADUATED
  SUSPENDED
}

enum TeacherStatus {
  PENDING
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum PaymentStatus {
  COMPLETE
  PENDING
  CANCELED
  FAILED
}

enum ScheduleColor {
  BLUE
  ORANGE
  YELLOW
  GREEN
  RED
  PURPLE
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELED
}
