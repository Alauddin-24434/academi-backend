// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    // directUrl = env("DIRECT_URL")
}

// ================= ENUM ==================
enum UserRole {
    STUDENT
    UNIVERSITY_ADMIN
    SUPER_ADMIN
}

enum ApplicationStatus {
    PENDING
    WAITING
    CONFIRMED
    REJECTED
}

enum PaymentStatus {
    PENDING
    SUCCESS
    FAILED
}

enum DepartmentCategory {
    SCIENCE
    HUMANITIES
    COMMERCE
}

enum PaymentType {
    APPLICATION
    ADMISSION
}

enum UniversityType {
    PUBLIC
    PRIVATE
    INTERNATIONAL
}

enum MethodType {
    CUSTOM
    GOOGLE
    FACEBOOK
    GITHUB
}

// ================= MODEL: User ==================
model User {
    id        String     @id @default(uuid())
    name      String
    email     String     @unique
    avatar    String?
    password  String
    role      UserRole   @default(STUDENT)
    method    MethodType @default(CUSTOM)
    phone     String?
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt

    applications     Application[]
    Payment          Payment[]
    ApplicationToken ApplicationToken?
}

// ================= MODEL: University ==================
model University {
    id             String         @id @default(ulid())
    name           String
    code           String         @unique
    location       String
    email          String?
    phone          String?
    logoUrl        String?
    websiteUrl     String?
    applicationFee Int?
    type           UniversityType
    isActive       Boolean        @default(true)
    createdAt      DateTime       @default(now())
    updatedAt      DateTime       @updatedAt

    universityDepartments UniversityDepartment[]
    applications          Application[]
    notices               Notice[]
    events                Event[]
}

// ================= MODEL: Department (Global) ==================
model Department {
    id        String             @id @default(uuid())
    name      String             @unique
    code      String             @unique
    category  DepartmentCategory
    createdAt DateTime           @default(now())
    updatedAt DateTime           @updatedAt

    universityDepartments UniversityDepartment[]
    applications          Application[]
}

// ================= MODEL: UniversityDepartment ==================
model UniversityDepartment {
    id           String @id @default(uuid())
    universityId String
    departmentId String
    seatCapacity Int

    university University @relation(fields: [universityId], references: [id])
    department Department @relation(fields: [departmentId], references: [id])

    @@unique([universityId, departmentId])
}

// ================= MODEL: Application ==================
model Application {
    id             String             @id @default(uuid())
    userId         String
    universityId   String
    departmentId   String
    status         ApplicationStatus  @default(PENDING)
    round          Int                @default(1)
    createdAt      DateTime           @default(now())
    category       DepartmentCategory
    boardName      String
    registrationNo String
    rollNo         String
    year           Int

    user       User       @relation(fields: [userId], references: [id])
    university University @relation(fields: [universityId], references: [id])
    department Department @relation(fields: [departmentId], references: [id])
    payment    Payment?
}

// ================= MODEL: Payment ==================
model Payment {
    id            String        @id @default(uuid())
    userId        String
    applicationId String?       @unique
    amount        Int
    type          PaymentType
    status        PaymentStatus
    transactionId String
    round         Int           @default(1)
    paidAt        DateTime?
    createdAt     DateTime      @default(now())

    user        User         @relation(fields: [userId], references: [id])
    application Application? @relation(fields: [applicationId], references: [id])
}

// ================= MODEL: Circular ==================
model Circular {
    id          String   @id @default(uuid())
    title       String
    description String?
    fileUrl     String?
    year        Int
    publishedAt DateTime @default(now())
}

// ================= MODEL: Notice ==================
model Notice {
    id           String   @id @default(cuid())
    title        String
    content      String
    universityId String
    publishedAt  DateTime @default(now())

    university University @relation(fields: [universityId], references: [id])
}

// ================= MODEL: ApplicationToken ==================
model ApplicationToken {
    id      String   @id @default(cuid())
    userId  String   @unique
    round   Int
    amount  Int
    paidAt  DateTime
    isValid Boolean  @default(true)

    user User @relation(fields: [userId], references: [id])
}

// ================= MODEL: FAQ ==================
model FAQ {
    id        String   @id @default(uuid())
    question  String
    answer    String
    imageUrl  String?
    createdAt DateTime @default(now())
}

// ================= MODEL: Event ==================
model Event {
    id           String   @id @default(uuid())
    title        String
    description  String
    universityId String
    date         DateTime
    year         Int
    location     String
    createdAt    DateTime @default(now())

    university University @relation(fields: [universityId], references: [id])

    @@unique([title, universityId, year])
}
